# --- ASR (Parakeet TDT — MLX, Apple Silicon only) ---
# https://huggingface.co/animaslabs/parakeet-tdt-0.6b-v3-mlx-4bit
ASR_MODEL=animaslabs/parakeet-tdt-0.6b-v3-mlx-4bit
ASR_SAMPLE_RATE=16000

# --- LLM (Ollama) ---
LLM_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=gemma4-obliterated:latest
# none = disable Gemma 4 thinking on Ollama /v1/chat/completions (set empty to omit)
LLM_REASONING_EFFORT=none

# --- TTS (OmniVoice; Apple GPU) ---
TTS_DEVICE=mps
OMNIVOICE_MODEL=k2-fsa/OmniVoice
OMNIVOICE_LANGUAGE=en

# Reference voice: defaults to ./reference.wav + ./reference.txt (created at setup).

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8890
