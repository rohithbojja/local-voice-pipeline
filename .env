# --- ASR (Faster-Whisper) ---
ASR_MODEL=large-v3-turbo
ASR_DEVICE=cuda
ASR_COMPUTE_TYPE=bfloat16
ASR_CPU_THREADS=0
ASR_LANGUAGE=en
ASR_SAMPLE_RATE=16000

# --- LLM (Ollama) ---
LLM_BASE_URL=http://127.0.0.1:8080
LLM_MODEL=Gemma-4-E4B-Uncensored-HauhauCS-Aggressive-7.52B-unknown.gguf

# --- TTS (Supertonic — https://github.com/supertone-inc/supertonic) ---
# pip install 'supertonic[serve]'

# Built-in preset voice (M1-M5, F1-F5). Ignored when SUPERTONIC_VOICE_JSON is set.
SUPERTONIC_VOICE=F1

# Custom cloned voice from Voice Builder (overrides SUPERTONIC_VOICE when set).
# Steps:
#   1. Go to https://supertonic.supertone.ai/voice-builder
#   2. Upload your reference.wav
#   3. Download the generated Supertonic 3 JSON
#   4. Put the JSON next to this file and set the path below
#SUPERTONIC_VOICE_JSON=./my_voice.json

SUPERTONIC_LANG=ja
SUPERTONIC_SPEED=1.05

# Quality/speed tradeoff: 2=fastest, 5=balanced (default), 8=medium, 10=high
SUPERTONIC_STEPS=10

# Optional thread tuning (leave blank = ONNX auto-detects)
#SUPERTONIC_INTRA_OP_THREADS=
#SUPERTONIC_INTER_OP_THREADS=

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8890
